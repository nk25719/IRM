# SQLite development
DATABASE_URL=sqlite:///./app/data/irm.db

# PostgreSQL local deployment
# DATABASE_URL=postgresql+psycopg://irm_user:change_me@db:5432/irm

# Docker/PostgreSQL defaults for local office deployment.
POSTGRES_DB=irm
POSTGRES_USER=irm_user
POSTGRES_PASSWORD=change_me

# Application file storage root. Do not point this at the Git repository in production.
IRM_DATA_ROOT=/data/irm

# Optional legacy SQLite path. Used only when DATABASE_URL is unset.
DB_PATH="./app/data/inventory.db"

# Optional: point this to your synced Excel file path.
EXCEL_PATH="./app/data/inventory_master.xlsx"
